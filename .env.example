# Backend
DATABASE_URL=postgres://mtg:change-me-to-secure-string@localhost:5432/mtg_meta?sslmode=disable
HTTP_ADDR=:8080
SESSION_COOKIE_NAME=mtg_session
SESSION_TTL_HOURS=720

# Google OAuth (OIDC) — issued by the Google Cloud console; paste them in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://cube.whitney.rip/api/auth/google/callback

# Scryfall / Moxfield
SCRYFALL_USER_AGENT=mtg-meta-tracker/0.1 (contact: you@example.com)
SCRYFALL_MIN_INTERVAL_MS=100

# On-disk cache for self-hosted card images. Empty (the default) means an
# ephemeral temp dir, which is what local dev uses. docker-compose.yml sets this
# to /data/images and mounts the card-images Docker volume there; the backend
# runs as uid 10001, so whatever this points at must be writable by that UID.
IMAGE_CACHE_DIR=

# First-admin bootstrap (applied only when the users table is empty). There is no
# public signup — this admin then creates everyone else. Email is optional.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=change-me-to-secure-string

# Next.js <- backend revalidation webhook. In Docker this is the compose
# service name (frontend), not localhost — the backend calls the frontend container.
REVALIDATE_URL=http://frontend:3000/api/revalidate
REVALIDATE_SECRET=change-me-to-secure-string

# Frontend (frontend/.env.local)
# BACKEND_ORIGIN=http://localhost:8080
# REVALIDATE_SECRET=change-me-to-secure-string

# Docker Compose deploy (Postgres credentials for the db service)
POSTGRES_USER=mtg
POSTGRES_PASSWORD=change-me-to-secure-string
POSTGRES_DB=mtg_meta
