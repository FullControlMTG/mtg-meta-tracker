# Backend
DATABASE_URL=postgres://mtg:mtg@localhost:5432/mtg_meta?sslmode=disable
HTTP_ADDR=:8080
SESSION_COOKIE_NAME=mtg_session
SESSION_TTL_HOURS=720

# Google OAuth (OIDC)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# Scryfall / Moxfield
SCRYFALL_USER_AGENT=mtg-meta-tracker/0.1 (contact: you@example.com)
SCRYFALL_MIN_INTERVAL_MS=100

# Frontend origin (for invite links)
APP_BASE_URL=http://localhost:3000

# First-admin bootstrap (applied only when the users table is empty).
# Admin-invites-only onboarding means the first admin must be seeded here.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=you@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-please

# Next.js -> backend revalidation webhook
REVALIDATE_URL=http://localhost:3000/api/revalidate
REVALIDATE_SECRET=change-me

# Frontend (frontend/.env.local)
# BACKEND_ORIGIN=http://localhost:8080
# REVALIDATE_SECRET=change-me

# Docker Compose deploy (Postgres credentials for the db service)
POSTGRES_USER=mtg
POSTGRES_PASSWORD=mtg
POSTGRES_DB=mtg_meta
